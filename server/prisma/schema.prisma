datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SalesRecord {
  id       Int      @id @default(autoincrement())
  region   String
  product  String
  amount   Float
  quantity Int      @default(0)
  saleDate DateTime @map("saleDate")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  industry  String
  revenue   Float
  createdAt DateTime @default(now()) @map("createdAt")
}